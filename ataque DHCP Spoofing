        with open("/proc/sys/net/ipv4/ip_forward", "w") as f:
            f.write("1")
        log.info("IP Forwarding habilitado.")
    except Exception as e:
        log.warning("No se pudo habilitar IP Forwarding automáticamente: %s", e)
        log.warning("Ejecuta manualmente: echo 1 | sudo tee /proc/sys/net/ipv4/ip_forward")


